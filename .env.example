# ============================================================
# Observability-IA — Environment Variables
# Copy this file to .env and adjust values before first run.
# NEVER commit secrets to version control.
# ============================================================

# --- Grafana ---
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme
GRAFANA_HOST=http://grafana:3000

# --- Ollama ---
OLLAMA_HOST=http://ollama:11434
# Model to pull and use for AI analysis (change to llama3, mistral, etc.)
OLLAMA_MODEL=llama3.2

# --- N8N ---
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=changeme
N8N_HOST=http://n8n:5678
# Public-facing URL (used in webhook URLs shown by N8N)
WEBHOOK_URL=http://localhost:5678/

# --- Prometheus ---
PROMETHEUS_HOST=http://prometheus:9090

# --- Loki ---
LOKI_HOST=http://loki:3100

# --- Alertmanager ---
ALERTMANAGER_HOST=http://alertmanager:9093

# --- Open WebUI ---
OPEN_WEBUI_PORT=8501
